include /usr/share/doc/newsboat/contrib/colorschemes/solarized-dark
# formats that deviate from the default
articlelist-format "%f %D %?T?|%-17T|  &?%t" 
datetime-format "%Y.%m.%d."
feedlist-format "%n %t %>  %U"

# bookmark config
bookmark-autopilot yes
bookmark-cmd "echo ${@} >> ~/sitesToRead/readinglist.txt"
bookmark-interactive false

# cleanup
cleanup-on-quit yes
delete-read-articles-on-quit no

# url viewer
external-url-viewer "urlview"

#other things that might deviate from default
auto-reload no
browser "dillo"
confirm-mark-all-feeds-read yes
max-items 10
html-renderer "w3m -dump -T text/html"
pager "internal"
prepopulate-query-feeds yes
refresh-on-startup no
reload-threads 20
search-highlight-colors "black" "yellow" "bold" 
show-keymap-hint no
show-read-articles yes
show-read-feeds yes

unbind-key -a
#keybindings, grouped by the dialogs they are used in
bind "," article,articlelist,feedlist,help macro-prefix 
bind "/" article,articlelist,feedlist,help open-search 
bind ":" article,articlelist,feedlist,help cmdline 
bind "j" article,articlelist,feedlist,help down 
bind "k" article,articlelist,feedlist,help up 
bind "q" article,articlelist,feedlist,help quit 

bind "?" article,articlelist,feedlist help 
bind "<ENTER>" article,articlelist,feedlist open 

bind "b" article,articlelist bookmark 
bind "o" article,articlelist open-in-browser 
bind "N" article,articlelist toggle-article-read 
bind "u" article,articlelist show-urls 

bind "A" articlelist,feedlist mark-feed-read 
bind "E" articlelist,feedlist edit-urls 
bind "r" articlelist,feedlist reload 

bind "R" feedlist reload-all 
bind "U" feedlist toggle-show-read-feeds 

highlight feedlist "---.*---" green default bold
highlight feedlist ".*0/0.." default default invis
